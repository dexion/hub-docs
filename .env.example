# Security Hub — пример переменных окружения для локального запуска.
#
# Скопируйте этот файл в .env и при необходимости измените значения:
#   cp .env.example .env
#
# Затем: docker compose up -d  и откройте http://localhost:3000
# Вход: admin@localhost.local / значение LOCAL_ADMIN_PASSWORD (ниже).

# ── Версия образов ───────────────────────────────────────────────────────────
# Тег публикуемых образов dexionius/sshub-*. Можно указать конкретную версию
# (например 0.24) или latest.
HUB_VERSION=0.24

# ── Аутентификация ───────────────────────────────────────────────────────────
# Пароль первого администратора (учётка admin@localhost.local). Пожалуйста,
# замените на собственный — значение по умолчанию приведено только для примера.
LOCAL_ADMIN_PASSWORD=Admin1234!

# ── Безопасность ─────────────────────────────────────────────────────────────
# Секрет подписи JWT. Обязательно замените на длинное случайное значение,
# например: openssl rand -hex 32
JWT_SECRET=please-change-this-to-a-random-secret

# ── База данных ──────────────────────────────────────────────────────────────
# Пароль PostgreSQL. Рекомендуем изменить.
DB_PASSWORD=securityhub123

# ── Порты (на хосте) ─────────────────────────────────────────────────────────
# Измените, если порты заняты другими сервисами.
FRONTEND_PORT=3000
BACKEND_PORT=8082

# ── Адреса (менять только если меняете порты выше) ───────────────────────────
# URL, по которому SPA в браузере обращается к backend API.
REACT_APP_API_URL=http://localhost:8082
# Базовый адрес фронтенда (для ссылок в уведомлениях и CORS).
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ── Время жизни токенов (опционально) ────────────────────────────────────────
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# ── Сканер DomainScope (опционально) ─────────────────────────────────────────
# Цели для сканирования (домены/CIDR через запятую). bootstrap добавит их в
# scope проекта; DomainScope (если запущен) заберёт и отсканирует. Токен и
# product_id для сканера создаются автоматически и сохраняются в общий том —
# вручную указывать не нужно.
DOMAINSCOPE_TARGETS=example.com
# Наполнить демонстрационными данными (проекты/находки) при инициализации.
SEED_DEMO_DATA=false
